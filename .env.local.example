# 개발용 Pro/Premium 잠금해제 (true로 설정 시 구독 체크 우회)
NEXT_PUBLIC_DEV_UNLOCK_PRO=false

# Supabase — 프로젝트 설정 > API에서 확인
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Railway FastAPI — 로컬 개발 시 http://localhost:8000
NEXT_PUBLIC_RAILWAY_API_URL=http://localhost:8000

# Upstash Redis — Upstash 콘솔에서 확인
UPSTASH_REDIS_REST_URL=your-upstash-url-here
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here
