{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "extraKnownMarketplaces": {
    "popup-studio-ai": {
      "source": {
        "source": "github",
        "repo": "popup-studio-ai/bkit-claude-code"
      },
      "autoUpdate": true
    }
  },
  "enabledPlugins": {
    "bkit@popup-studio-ai": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(git:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(uvicorn:*)",
      "Bash(pytest:*)",
      "Bash(uv:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(touch:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(jq:*)",
      "Bash(curl:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(tsc:*)",
      "Bash(next:*)",
      "Bash(supabase:*)",
      "Bash(vercel:*)",
      "Bash(railway:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(kill:*)",
      "Bash(ps:*)",
      "Bash(lsof:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(diff:*)",
      "Bash(chmod:*)",
      "Bash(open:*)",
      "Bash(brew:*)",
      "Bash(sleep:*)",
      "Bash(date:*)",
      "Bash(cursor:*)",
      "Bash(type:*)",
      "Bash(env:*)",
      "Bash(export:*)",
      "Bash(source:*)",
      "Bash(true:*)",
      "Bash(false:*)",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "NotebookRead",
      "NotebookEdit"
    ]
  }
}
